{
  "name": "elect-ai",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered multilingual civic assistant for Indian election education — built with Google Gemini, Vertex AI, Firebase, and Cloud Run for H2S PromptWars Challenge 2.",
  "keywords": ["election", "india", "gemini", "vertex-ai", "civic-tech", "multilingual", "firebase", "cloud-run"],
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"vite --host\"",
    "backend": "node --watch server.js",
    "start": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@google-cloud/vertexai": "^1.0.0",
    "@google/generative-ai": "^0.21.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "firebase": "^11.0.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
