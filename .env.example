# ─────────────────────────────────────────────────────────────
# ElectAI — Environment Configuration Example
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to git.
# ─────────────────────────────────────────────────────────────

# ── AI STUDIO API KEYS ──
# Get free API keys at: https://aistudio.google.com/app/apikey
# Add up to 3 keys for round-robin quota sharing
# Each key = ~1,500 free requests/day on gemini-2.0-flash
# Recommended: 3 keys = ~4,500 requests/day
GEMINI_API_KEY_1=your_primary_ai_studio_key_here
GEMINI_API_KEY_2=your_second_ai_studio_key_here
GEMINI_API_KEY_3=your_third_ai_studio_key_here

# ── VERTEX AI (Optional Fallback — GCP Cloud Credits, NO credit card) ──
# 1. Go to: https://console.cloud.google.com
# 2. Enable: "Vertex AI API"
# 3. Set your GCP project ID below
# 4. For Cloud Run: Service Account auto-provides credentials (no JSON key needed)
# 5. For local dev: run `gcloud auth application-default login`
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1

# ── FIREBASE CONFIGURATION ──
# Get from: Firebase Console → Project Settings → Web App
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id